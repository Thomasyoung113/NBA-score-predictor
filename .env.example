# Get a free key at https://balldontlie.io
BALLDONTLIE_API_KEY=

# Vercel dashboard → Storage → Marketplace Database Providers → Redis
# (injects these two automatically once connected to this project)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional: protects /api/evaluate from being triggered by anyone but
# Vercel Cron. Generate any random string and set the same value in
# Vercel's Environment Variables.
CRON_SECRET=
